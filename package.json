{
  "name": "cheque-processor",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.5",
    "@stripe/stripe-js": "^8.5.2",
    "autoprefixer": "^10.4.0",
    "axios": "^1.13.2",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.2",
    "react-scripts": "5.0.1",
    "resend": "^0.15.0",
    "stripe": "^20.0.0",
    "tailwindcss": "^3.3.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "npm-run-all": "^4.1.5"
  },
  "workspaces": [
    "front-end",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
